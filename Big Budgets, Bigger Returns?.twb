      <aliases enabled='yes' />
      <column caption='Vaild ROI Movie' datatype='boolean' name='[Calculation_0196054449119232]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[budget] &gt;= 1000000 AND [revenue] &gt; 0' />
      </column>
      <column caption='Revenue-to-Budget Ratio' datatype='real' name='[Calculation_0196054449852417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[revenue] / [budget]' />
      </column>
      <column caption='Budget Category' datatype='string' name='[Calculation_0196054450073602]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [budget] &lt; 25000000 THEN &quot;Low Budget&quot; ELSEIF [budget] &lt; 100000000 THEN &quot;Mid Budget&quot; ELSE &quot;High Budget&quot; END' />
      </column>
      <column caption='Avg Return Ratio by Budget Category' datatype='real' name='[Calculation_0196054450794499]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_0196054450073602] : AVG([Calculation_0196054449852417]) }' />
      </column>
      <column caption='Avg Return Ratio by Genre' datatype='real' name='[Calculation_0196054451507204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [genres] : AVG([Calculation_0196054449852417]) }' />
      </column>
      <column caption='Movie Count' datatype='integer' name='[Calculation_0196054452277253]' role='measure' type='quantitative'>
